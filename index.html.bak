    content: `# Meta-Gomen Toolset Architecture
## Agent-Specific Tool Integration v0.5

---

## Overview

Each agent in Meta-Gomen has access to specific tools that extend its capabilities beyond pure language generation.

**Design Principles:**
1. **Right tool for right task** - LLMs orchestrate, tools compute
2. **Provenance tracking** - Every tool output marked with source
3. **Reproducibility** - Tool outputs are deterministic and verifiable
4. **Graceful degradation** - Agents work without tools, just less precisely

---

## 1. Tool Categories

### Computation Tools
| Tool | Purpose |
|------|---------|
| SymPy | Symbolic math, algebra, calculus |
| NumPy | Numerical computation, linear algebra |
| SciPy | Scientific computing, statistics |
| Pint | Unit conversions |
| mpmath | Arbitrary precision arithmetic |

### Chemistry/Biology Tools
| Tool | Purpose |
|------|---------|
| RDKit | Molecular structure, properties |
| PubChemPy | Chemical database lookup |
| Biopython | Sequence analysis |
| ChEMBL | Bioactivity database |

### Graph/Network Tools
| Tool | Purpose |
|------|---------|
| NetworkX | Graph algorithms |
| igraph | Large-scale graph analysis |
| PyVis | Graph visualization |

### External API Tools
| Tool | Purpose |
|------|---------|
| Wolfram Alpha | General computation oracle |
| Semantic Scholar | Academic paper search |
| arXiv API | Preprint access |
| CrossRef | DOI/citation lookup |

---

## 2. Agent Tool Assignments

### FORAGER Tools
**Purpose**: Extract, parse, and structure incoming content

- Document processing: PyMuPDF, python-docx, markdownify
- Metadata extraction: CrossRef, arXiv API
- Content analysis: langdetect, dateparser, spaCy

### WEAVER Tools
**Purpose**: Analyze connections, compute graph metrics

- Graph analysis: NetworkX, community detection
- Text analysis: sklearn, sentence_transformers
- Statistics: scipy.stats, numpy
- Database: sqlite3, DuckDB

### DREAMER Tools
**Purpose**: Minimal tools - DREAMER is about speculation

- Sampling: random, numpy.random
- Optional lookup: Wikipedia API

> Dreams don't need to be verified. They need to be generative.

### SCHOLAR Tools
**Purpose**: Academic rigor, citations, literature review

- Literature search: Semantic Scholar, arXiv, CrossRef
- Citation management: BibTeX, citeproc
- Text analysis: spaCy, sklearn
- Formatting: Pandoc, LaTeX

### SCIENTIST Tools
**Purpose**: Quantitative analysis, empirical verification

- Computation: SymPy, NumPy, SciPy, mpmath
- Chemistry: RDKit, PubChemPy
- Statistics: scipy.stats, statsmodels
- Visualization: Matplotlib, Plotly
- External: Wolfram Alpha

### SAGE Tools
**Purpose**: Synthesis coordination, Earth Star alignment

- Synthesis: Jinja2, Markdown
- Graph traversal: NetworkX
- Quorum coordination: asyncio
- Earth Star metrics: custom coherence calculators
- Visualization: Mermaid, Graphviz

---

## 3. Tool Interface Specification

### Standard Tool Interface

\`\`\`python
class ToolResult:
    success: bool
    output: Any
    provenance: Dict
    execution_time: float
    error: Optional[str]

class ToolProvenance:
    tool_name: str
    tool_version: str
    input_hash: str
    output_hash: str
    executed_at: datetime
    reproducible: bool
    confidence: str  # "exact", "approximate", "estimated"
\`\`\`

---

## 4. Agent-Tool Matrix Summary

| Agent | Primary Tools | Forbidden Tools |
|-------|--------------|-----------------|
| FORAGER | PyMuPDF, CrossRef | computation |
| WEAVER | NetworkX, sklearn | external APIs |
| DREAMER | random sampling | verification |
| SCHOLAR | Semantic Scholar | computation |
| SCIENTIST | SymPy, RDKit | literature |
| SAGE | NetworkX, Jinja2 | primary analysis |

---

*Tools extend agents' capabilities while maintaining reproducibility and provenance.*`
  }
];

// ============================================
// ARCHIVE STATE
// ============================================
let archiveCurrentFilter = 'all';
let archiveSearchQuery = '';
let archiveCurrentDocId = null;

// ============================================
// RENDER ARCHIVE GRID
// ============================================
function archiveRenderGrid() {
  const grid = document.getElementById('archiveGrid');
  let filtered = ARCHIVE_DOCS;

  if (archiveCurrentFilter !== 'all') {
    filtered = filtered.filter(d => d.category === archiveCurrentFilter);
  }

  if (archiveSearchQuery) {
    const q = archiveSearchQuery.toLowerCase();
    filtered = filtered.filter(d =>
      d.title.toLowerCase().includes(q) ||
      d.description.toLowerCase().includes(q) ||
      d.tags.some(t => t.toLowerCase().includes(q)) ||
      d.content.toLowerCase().includes(q)
    );
  }

  if (filtered.length === 0) {
    grid.innerHTML = '<div class="archive-empty">no documents found</div>';
    return;
  }

  grid.innerHTML = filtered.map(doc => `
    <div class="archive-card" data-category="${doc.category}" onclick="archiveOpenDoc('${doc.id}')">
      <span class="archive-card-category">${doc.category}</span>
      <div class="archive-card-title">${doc.title}</div>
      <div class="archive-card-desc">${doc.description}</div>
      <div class="archive-card-tags">
        ${doc.tags.map(t => `<span class="archive-tag">${t}</span>`).join('')}
      </div>
    </div>
  `).join('');
}

// ============================================
// SEARCH & FILTER
// ============================================
function archiveHandleSearch(q) {
  archiveSearchQuery = q;
  archiveRenderGrid();
}

function archiveSetFilter(cat) {
  archiveCurrentFilter = cat;
  archiveRenderGrid();
}

// ============================================
// MARKDOWN RENDERER
// ============================================
function archiveRenderMarkdown(text) {
  let html = '';
  const lines = text.split('\n');
  let inCode = false, codeLines = [];
  let inTable = false, tableLines = [];

  function flushTable() {
    if (!tableLines.length) return '';
    let t = '<table>';
    tableLines.forEach((row, i) => {
      const cells = row.split('|').filter(c => c.trim() !== '');
      if (i === 1 && cells.every(c => /^[\s-:]+$/.test(c))) return;
      const tag = i === 0 ? 'th' : 'td';
      t += '<tr>' + cells.map(c => `<${tag}>${inlineFormat(c.trim())}</${tag}>`).join('') + '</tr>';
    });
    t += '</table>';
    tableLines = [];
    inTable = false;
    return t;
  }

  function inlineFormat(s) {
    s = s.replace(/`([^`]+)`/g, '<code>$1</code>');
    s = s.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');
    s = s.replace(/\*([^*]+)\*/g, '<em>$1</em>');
    s = s.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank">$1</a>');
    return s;
  }

  for (let i = 0; i < lines.length; i++) {
    const line = lines[i];

    if (line.startsWith('\`\`\`')) {
      if (inCode) {
        html += '<pre><code>' + codeLines.join('\n').replace(/</g, '&lt;').replace(/>/g, '&gt;') + '</code></pre>';
        codeLines = [];
        inCode = false;
      } else {
        if (inTable) html += flushTable();
        inCode = true;
      }
      continue;
    }

    if (inCode) {
      codeLines.push(line);
      continue;
    }

    if (line.includes('|') && line.trim().startsWith('|')) {
      if (!inTable) inTable = true;
      tableLines.push(line.trim());
      continue;
    } else if (inTable) {
      html += flushTable();
    }

    if (/^#{1,4}\s/.test(line)) {
      const lvl = line.match(/^(#+)/)[1].length;
      const text = line.replace(/^#+\s*/, '');
      html += '<h' + lvl + '>' + inlineFormat(text) + '</h' + lvl + '>';
    } else if (line.startsWith('---') || line.startsWith('***') || line.startsWith('___')) {
      html += '<hr>';
    } else if (line.startsWith('> ')) {
      html += '<blockquote>' + inlineFormat(line.slice(2)) + '</blockquote>';
    } else if (/^\s*[-*]\s/.test(line)) {
      if (!html.endsWith('</ul>')) html += '<ul>';
      else html = html.replace(/<\/ul>$/, '');
      html += '<li>' + inlineFormat(line.replace(/^\s*[-*]\s/, '')) + '</li></ul>';
    } else if (/^\s*\d+\.\s/.test(line)) {
      if (!html.endsWith('</ol>')) html += '<ol>';
      else html = html.replace(/<\/ol>$/, '');
      html += '<li>' + inlineFormat(line.replace(/^\s*\d+\.\s/, '')) + '</li></ol>';
    } else if (line.trim() === '') {
      // skip
    } else {
      html += '<p>' + inlineFormat(line) + '</p>';
    }
  }

  if (inTable) html += flushTable();
  if (inCode) html += '<pre><code>' + codeLines.join('\n').replace(/</g, '&lt;').replace(/>/g, '&gt;') + '</code></pre>';

  return html;
}

// ============================================
// OPEN / CLOSE PANEL
// ============================================
function archiveOpenDoc(id) {
  const doc = ARCHIVE_DOCS.find(d => d.id === id);
  if (!doc) return;

  archiveCurrentDocId = id;

  document.getElementById('archivePanel').classList.add('open');
  document.getElementById('archivePanelOverlay').classList.add('open');
  document.body.style.overflow = 'hidden';

  // Update breadcrumbs
  document.getElementById('archiveBreadcrumbs').innerHTML = `
    <span class="archive-crumb archive-crumb-root" onclick="archiveClosePanel()">The Archive</span>
    <span class="archive-crumb-sep">/</span>
    <span class="archive-crumb">${doc.category}</span>
    <span class="archive-crumb-sep">/</span>
    <span class="archive-crumb archive-crumb-title">${doc.title}</span>
  `;

  // Render content
  document.getElementById('archivePanelBody').innerHTML = '<div class="archive-md">' + archiveRenderMarkdown(doc.content) + '</div>';
  document.getElementById('archivePanelBody').scrollTop = 0;

  archiveUpdateNav();
}

function archiveClosePanel() {
  document.getElementById('archivePanel').classList.remove('open');
  document.getElementById('archivePanelOverlay').classList.remove('open');
  document.body.style.overflow = '';
  archiveCurrentDocId = null;
}

// ============================================
// NAVIGATION
// ============================================
function archiveGetDocIndex(id) {
  return ARCHIVE_DOCS.findIndex(d => d.id === id);
}

function archiveNavPrev() {
  const idx = archiveGetDocIndex(archiveCurrentDocId);
  if (idx > 0) {
    archiveOpenDoc(ARCHIVE_DOCS[idx - 1].id);
  }
}

function archiveNavNext() {
  const idx = archiveGetDocIndex(archiveCurrentDocId);
  if (idx >= 0 && idx < ARCHIVE_DOCS.length - 1) {
    archiveOpenDoc(ARCHIVE_DOCS[idx + 1].id);
  }
}

function archiveUpdateNav() {
  const idx = archiveGetDocIndex(archiveCurrentDocId);
  const prev = idx > 0 ? ARCHIVE_DOCS[idx - 1] : null;
  const next = idx < ARCHIVE_DOCS.length - 1 ? ARCHIVE_DOCS[idx + 1] : null;

  document.getElementById('archiveBtnPrev').disabled = !prev;
  document.getElementById('archiveBtnNext').disabled = !next;

  const prevEl = document.getElementById('archiveFooterPrev');
  const nextEl = document.getElementById('archiveFooterNext');

  if (prev) {
    prevEl.removeAttribute('disabled');
    document.getElementById('archivePrevName').textContent = prev.title;
  } else {
    prevEl.setAttribute('disabled', '');
    document.getElementById('archivePrevName').textContent = '';
  }

  if (next) {
    nextEl.removeAttribute('disabled');
    document.getElementById('archiveNextName').textContent = next.title;
  } else {
    nextEl.setAttribute('disabled', '');
    document.getElementById('archiveNextName').textContent = '';
  }
}

// ============================================
// KEYBOARD SHORTCUTS
// ============================================
document.addEventListener('keydown', function(e) {
  if (!document.getElementById('archivePanel').classList.contains('open')) return;

  if (e.key === 'Escape') {
    archiveClosePanel();
    e.preventDefault();
  } else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
    archiveNavPrev();
    e.preventDefault();
  } else if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {
    archiveNavNext();
    e.preventDefault();
  }
});

// ============================================
// INIT ARCHIVE
// ============================================
archiveRenderGrid();
</script>

    <footer>
      <div class="footer-garden" id="footerGarden"></div>
      <button onclick="clearGarden()" class="clear-garden-btn" title="Clear garden">Clear Garden</button>
      <img src="./Assets/EarthStar Logo JH 2025 w.webp" alt="Logo" class="footer-logo">
      <p>earth star is live</p>
      <p class="footer-tagline">"Plant the seed. Tend the soil."</p>
      <p class="footer-equation">Gomen'nasai — entropy's algorithmic antithesis</p>
      <a href="https://www.johnhanacek.com" class="link-btn-jewel" target="_blank">By JHDesign</a>
      <div class="banner-footer">
        <img src="./Assets/EarthstarBanner.webp" alt="EarthStar Banner">
      </div>
    </footer>
  
  <script>
    // Emoji Garden System
    
    // Configuration
    const CONFIG = {
      heroLeft: { emoji: '✦', max: 8 },
      bodyPersistent: { emojis: ['✦'], max: 5 },
      bodyTransient: { emojis: ['🌱', '🌿', '🌸'], maxVisible: 22 },
      footerGarden: { emojis: ['🌱', '🌿', '🌸'], max: 14 }
    };
    
    // State
    let state = {
      heroLeft: [],
      heroRight: [],
      bodyPersistent: [],
      footerGarden: [],
      itemsSinceLastTree: 0
    };
    
    // Living butterflies state
    let butterflies = [];
    let mouseX = window.innerWidth / 2;
    let mouseY = window.innerHeight / 2;
    let mouseOnPage = false;
    let animationFrameId = null;
    
    // Load state from localStorage
    function loadState() {
      try {
        const saved = localStorage.getItem('earthStarGarden');
        if (saved) {
          const savedState = JSON.parse(saved);
          // Convert old footer emojis to new plant/flower emojis
          const plantEmojis = CONFIG.footerGarden.emojis;
          state = {
            heroLeft: savedState.heroLeft || [],
            heroRight: savedState.heroRight || [],
            bodyPersistent: savedState.bodyPersistent || [],
            footerGarden: (savedState.footerGarden || []).map(item => ({
              emoji: item.emoji || plantEmojis[Math.floor(Math.random() * plantEmojis.length)],
              timestamp: item.timestamp || Date.now(),
              isTree: item.isTree || false,
              isNew: false
            })),
            itemsSinceLastTree: savedState.itemsSinceLastTree || 0
          };
        }
      } catch (e) {
        console.log('Could not load garden state');
      }
    }
    
    // Save state to localStorage
    function saveState() {
      try {
        localStorage.setItem('earthStarGarden', JSON.stringify(state));
      } catch (e) {
        console.log('Could not save garden state');
      }
    }
    
    // Clear state and refresh
    function clearGarden() {
      localStorage.removeItem('earthStarGarden');
      state = { heroLeft: [], bodyPersistent: [], footerGarden: [], itemsSinceLastTree: 0 };
      butterflies = [];
      // Remove all living butterflies from DOM
      document.querySelectorAll('.butterfly-living').forEach(el => el.remove());
      renderFooterGarden();
      // Remove all existing persistent emojis
      document.querySelectorAll('.emoji-persistent, .emoji-fading').forEach(el => el.remove());
      console.log('Garden cleared!');
    }
    
    // Create transient emoji (fades after 2s, adds to footer when done)
    function createTransientEmoji(x, y) {
      const emoji = document.createElement('div');
      emoji.className = 'emoji-transient';
      emoji.textContent = CONFIG.bodyTransient.emojis[Math.floor(Math.random() * CONFIG.bodyTransient.emojis.length)];
      emoji.style.left = (x - 12) + 'px';
      emoji.style.top = (y - 12) + 'px';
      document.body.appendChild(emoji);
      
      setTimeout(() => {
        emoji.remove();
        // Add a plant to footer when transient emoji fades
        addPlantToFooter();
      }, 2000);
    }
    
    // Just add a plant to footer (called when transient emoji fades)
    function addPlantToFooter() {
      const emojiChar = CONFIG.footerGarden.emojis[Math.floor(Math.random() * CONFIG.footerGarden.emojis.length)];
      
      // Add as new item
      state.footerGarden.push({
        emoji: emojiChar,
        timestamp: Date.now(),
        isNew: true,
        isTree: false
      });
      
      state.itemsSinceLastTree++;
      console.log('Added plant, itemsSinceLastTree:', state.itemsSinceLastTree);
      
      // Every 5 items, transform oldest to tree
      if (state.itemsSinceLastTree >= 5 && state.footerGarden.length > 0) {
        console.log('Tree evolution triggered!');
        // Find oldest non-tree item
        for (let i = 0; i < state.footerGarden.length; i++) {
          if (!state.footerGarden[i].isTree) {
            state.footerGarden[i].emoji = '🌳';
            state.footerGarden[i].isTree = true;
            state.footerGarden[i].isNew = true; // Re-animate as tree
            state.itemsSinceLastTree = 0;
            console.log('A tree has grown! Index:', i);
            break;
          }
        }
      }
      
      // Remove oldest if over max (but keep trees!)
      while (state.footerGarden.length > CONFIG.footerGarden.max) {
        // Prioritize removing non-trees
        let removeIdx = -1;
        for (let i = 0; i < state.footerGarden.length; i++) {
          if (!state.footerGarden[i].isTree) {
            removeIdx = i;
            break;
          }
        }
        // If all are trees, remove first one
        if (removeIdx === -1) removeIdx = 0;
        state.footerGarden.splice(removeIdx, 1);
      }
      
      saveState();
      renderFooterGarden();
    }
    
    // Create persistent emoji (floats in place)
    function createPersistentEmoji(x, y, emojiChar, container = document.body, offsetY = 0) {
      const el = document.createElement('div');
      el.className = 'emoji-persistent';
      el.textContent = emojiChar;
      el.style.left = (x - 14) + 'px';
      el.style.top = (y - 14 + offsetY) + 'px';
      el.dataset.x = x;
      el.dataset.y = y;
      el.dataset.emoji = emojiChar;
      document.body.appendChild(el);
      return el;
    }
    
    // Fade away and remove emoji when limit exceeded
    function fadeAwayEmoji(x, y, emojiChar) {
      const el = document.createElement('div');
      el.className = 'emoji-fading';
      el.textContent = emojiChar;
      el.style.left = (x - 14) + 'px';
      el.style.top = (y - 14) + 'px';
      document.body.appendChild(el);
      setTimeout(() => el.remove(), 800);
    }
    
    // Add to footer garden (always plants/flowers)
    function addToFooterGarden() {
      addPlantToFooter();
    }
    
    // Render footer garden
    function renderFooterGarden() {
      const garden = document.getElementById('footerGarden');
      if (!garden) {
        console.log('Footer garden element NOT FOUND');
        return;
      }
      garden.innerHTML = '';
      
      if (state.footerGarden.length === 0) {
        garden.innerHTML = '<span style="font-size: 0.8em; color: rgba(168,155,133,0.5);">click margins to plant...</span>';
        return;
      }
      
      state.footerGarden.forEach((item, index) => {
        const el = document.createElement('span');
        // Add classes for animation
        if (item.isNew) {
          el.className = item.isTree ? 'emoji-footer tree' : 'emoji-footer new';
          item.isNew = false; // Mark as seen after first render
        } else {
          el.className = 'emoji-footer';
        }
        el.textContent = item.emoji;
        el.title = item.isTree ? 'A grown tree. Click to remove. ' + (5 - state.itemsSinceLastTree) + ' more until next tree.' : 'Click to remove. ' + (5 - state.itemsSinceLastTree) + ' more until next tree.';
        el.addEventListener('click', (e) => {
          e.stopPropagation();
          state.footerGarden.splice(index, 1);
          // Reset tree counter if we removed a tree
          if (item.isTree) {
            state.itemsSinceLastTree = 0;
          }
          saveState();
          renderFooterGarden();
        });
        garden.appendChild(el);
      });
    }
    
    // Living butterfly system (max 5)
    function createLivingButterfly(x, y) {
      const el = document.createElement('div');
      el.className = 'butterfly-living';
      el.textContent = '🦋';
      // Random offset to prevent stacking
      const offsetX = (Math.random() - 0.5) * 40;
      const offsetY = (Math.random() - 0.5) * 40;
      const spawnX = x + offsetX;
      const spawnY = y + offsetY;
      el.style.left = (spawnX - 12) + 'px';
      el.style.top = (spawnY - 12) + 'px';
      document.body.appendChild(el);
      
      const butterfly = {
        el: el,
        x: spawnX,
        y: spawnY,
        vx: (Math.random() - 0.5) * 1.5,
        vy: (Math.random() - 0.5) * 1.5,
        angle: Math.random() * 360,
        birthTime: Date.now()
      };
      
      butterflies.push(butterfly);
      
      // Max 5, fade oldest when over limit (no footer)
      while (butterflies.length > 5) {
        const old = butterflies.shift();
        if (old && old.el) {
          old.el.style.transition = 'opacity 0.5s, transform 0.5s';
          old.el.style.opacity = '0';
          old.el.style.transform = 'scale(0)';
          setTimeout(() => old.el?.remove(), 500);
        }
      }
      
      return butterfly;
    }
    
    function updateButterflies() {
      // Clean up stale references
      butterflies = butterflies.filter(b => b && b.el && b.el.parentElement);
      
      butterflies.forEach((b, i) => {
        // Skip invalid butterflies
        if (!b.el || !b.el.parentElement) return;
        
        if (mouseOnPage) {
          // Cursor on page: orbit around cursor at gentle distance
          const dx = b.x - mouseX;
          const dy = b.y - mouseY;
          const dist = Math.sqrt(dx * dx + dy * dy);
          
          // Each butterfly has slightly different target distance for spread
          const baseTarget = 100 + (i * 20);
          const targetDist = baseTarget + Math.sin(Date.now() / 3000 + b.x * 0.01 + i) * 30;
          
          // Each butterfly orbits at different speed
          const orbitSpeed = 0.4 + (i * 0.1);
          b.angle += orbitSpeed;
          
          // Avoid center of cursor (50px exclusion zone)
          if (dist < 50) {
            // Too close - push away strongly
            b.vx += (dx / dist) * 0.2;
            b.vy += (dy / dist) * 0.2;
          } else if (dist < targetDist - 30) {
            // Too close - drift away faster
            b.vx += (dx / dist) * 0.08;
            b.vy += (dy / dist) * 0.08;
          } else if (dist > targetDist + 30) {
            // Too far - drift closer faster
            b.vx -= (dx / dist) * 0.06;
            b.vy -= (dy / dist) * 0.06;
          }
          
          // Add gentle orbit tangential force
          const orbitStrength = 0.008;
          b.vx += Math.cos(b.angle) * orbitStrength;
          b.vy += Math.sin(b.angle) * orbitStrength;
        } else {
          // Cursor off page: gentle random wandering with unique patterns per butterfly
          b.angle += (Math.random() - 0.5) * (2 + i * 0.5);
          const wanderStrength = 0.05 + (i * 0.01);
          b.vx += Math.cos(b.angle * Math.PI / 180) * wanderStrength;
          b.vy += Math.sin(b.angle * Math.PI / 180) * wanderStrength;
        }
        
        // Gentle damping
        b.x += b.vx;
        b.y += b.vy;
        b.vx *= 0.94;
        b.vy *= 0.94;
        
        // Each butterfly has different max speed (faster when cursor on page)
        const maxSpeed = mouseOnPage ? 4 + (i * 0.3) : 2 + (i * 0.2);
        const currentSpeed = Math.sqrt(b.vx * b.vx + b.vy * b.vy);
        if (currentSpeed > maxSpeed) {
          b.vx = (b.vx / currentSpeed) * maxSpeed;
          b.vy = (b.vy / currentSpeed) * maxSpeed;
        }
        
        // Minimum movement
        if (currentSpeed < 0.2) {
          b.vx += (Math.random() - 0.5) * 0.15;
          b.vy += (Math.random() - 0.5) * 0.15;
        }
        
        // Soft bounds
        const margin = 80;
        if (b.x < margin) { b.x = margin; b.vx = Math.abs(b.vx) * 0.6; }
        if (b.x > window.innerWidth - margin) { b.x = window.innerWidth - margin; b.vx = -Math.abs(b.vx) * 0.6; }
        if (b.y < margin) { b.y = margin; b.vy = Math.abs(b.vy) * 0.6; }
        if (b.y > window.innerHeight - margin) { b.y = window.innerHeight - margin; b.vy = -Math.abs(b.vy) * 0.6; }
        
        // Update element with unique wing flap phase per butterfly
        const facingRight = b.vx > 0;
        const wingFlap = Math.sin(Date.now() / 150 + b.y * 0.05 + i * 10) * 0.08 + 1;
        b.el.style.transform = `scaleX(${facingRight ? 1 : -1}) scale(${wingFlap})`;
        b.el.style.left = (b.x - 12) + 'px';
        b.el.style.top = (b.y - 12) + 'px';
      });
      
      animationFrameId = requestAnimationFrame(updateButterflies);
    }
    
    // Track mouse position and page presence
    document.addEventListener('mousemove', (e) => {
      mouseX = e.clientX;
      mouseY = e.clientY;
      mouseOnPage = true;
    });
    
    document.addEventListener('mouseleave', () => {
      mouseOnPage = false;
    });
    
    document.addEventListener('mouseenter', () => {
      mouseOnPage = true;
    });
    
    // Handle margin click (stars on both sides)
    function handleMarginClick(e, isLeft) {
      const x = isLeft ? 40 : window.innerWidth - 40;
      const y = e.clientY;
      
      // Add star to state
      const side = isLeft ? 'heroLeft' : 'heroRight';
      if (!state[side]) state[side] = [];
      state[side].push({ x, y, timestamp: Date.now() });
      
      // Check limit - fade away oldest (no footer, just stars)
      if (state[side].length > CONFIG.heroLeft.max) {
        const old = state[side].shift();
        fadeAwayEmoji(old.x, old.y, CONFIG.heroLeft.emoji);
      }
      
      // Create visual star
      createPersistentEmoji(x, y, CONFIG.heroLeft.emoji, document.body, -20);
      
      saveState();
    }
    
    // Handle hero left margin click (stars)
    function handleHeroLeftClick(e) {
      handleMarginClick(e, true);
    }
    
    // Handle hero right margin click (stars)
    function handleHeroRightClick(e) {
      handleMarginClick(e, false);
    }
    
    // Handle body area click
    function handleBodyClick(e) {
      const x = e.clientX;
      const y = e.clientY;
      
      // 70% chance: transient (sprouts), 30% chance: animated living butterfly
      const isPersistent = Math.random() < 0.3;
      
      if (isPersistent) {
        // Animated living butterfly (max 5)
        createLivingButterfly(x, y);
      } else {
        // Transient element
        createTransientEmoji(x, y);
      }
    }
    
    // Initialize
    function init() {
      console.log('Emoji garden initializing...');
      loadState();
      renderFooterGarden();
      
      console.log('State loaded:', state);
      
      // Restore persistent elements on page
      state.heroLeft.forEach(item => {
        createPersistentEmoji(item.x, item.y, CONFIG.heroLeft.emoji, document.body, -20);
      });
      
      state.heroRight.forEach(item => {
        createPersistentEmoji(item.x, item.y, CONFIG.heroLeft.emoji, document.body, -20);
      });
      
      // Body persistent was only for stars/butterflies, now we use living butterflies only
      // No restoration needed for bodyPersistent since we now use living butterflies
      
      // Single document click handler - check areas
      document.addEventListener('click', function handleClick(e) {
        console.log('Document click at:', e.clientX, e.clientY);
        // Skip if clicking on footer garden items
        if (e.target.closest('.emoji-footer') || e.target.closest('.footer-garden')) {
          console.log('Click on footer garden - skipping');
          return;
        }
        
        // Visual debug - brief flash at click point
        const debug = document.createElement('div');
        debug.style.cssText = 'position:fixed;width:10px;height:10px;background:gold;border-radius:50%;pointer-events:none;z-index:10002;left:'+(e.clientX-5)+'px;top:'+(e.clientY-5)+'px;animation:fadeOut 0.3s forwards';
        document.body.appendChild(debug);
        setTimeout(() => debug.remove(), 300);
        
        const marginLeft = e.clientX < 80;
        const marginRight = e.clientX > window.innerWidth - 80;
        
        if (marginLeft) {
          handleHeroLeftClick(e);
        } else if (marginRight) {
          handleHeroRightClick(e);
        } else {
          // Body area click
          handleBodyClick(e);
        }
      });
      
      // Add fadeOut keyframe
      const style = document.createElement('style');
      style.textContent = '@keyframes fadeOut { to { opacity: 0; transform: scale(2); } }';
      document.head.appendChild(style);
      
      // Start butterfly animation
      updateButterflies();
      
      console.log('Emoji garden ready!');
    }
    
    // Parallax code (unchanged)
    const hero = document.querySelector('.hero');
    const images = document.querySelectorAll('.hero-images img');
    const depths = [1, 5, 20, 50, 8];
    const scales = [1, 1, 1, 1.05, 1];
    let currentX = 0, currentY = 0, targetX = 0, targetY = 0;
    
    function updateParallax() {
      currentX += (targetX - currentX) * 0.15;
      currentY += (targetY - currentY) * 0.15;
      const diff = Math.abs(targetX - currentX) + Math.abs(targetY - currentY);
      images.forEach((img, i) => {
        const depth = depths[i];
        const scale = scales[i];
        const tx = currentX * depth;
        const ty = currentY * depth;
        img.style.transform = `translate3d(${tx}px, ${ty}px, 0) scale(${scale})`;
      });
      if (diff > 0.1) requestAnimationFrame(updateParallax);
    }
    
    hero.addEventListener('mousemove', (e) => {
      const rect = hero.getBoundingClientRect();
      targetX = ((e.clientX - rect.left) / rect.width - 0.5) * 2;
      targetY = ((e.clientY - rect.top) / rect.height - 0.5) * 2;
      requestAnimationFrame(updateParallax);
    });
    
    hero.addEventListener('mouseleave', () => {
      targetX = 0; targetY = 0;
      requestAnimationFrame(updateParallax);
      images.forEach((img) => {
        img.style.transition = 'transform 0.5s ease-out';
      });
    });
    
    hero.addEventListener('mouseenter', () => {
      images.forEach((img) => {
        img.style.transition = 'transform 0.1s ease-out';
      });
    });
    
    // Start
    init();
  </script>
</body>
</html>
